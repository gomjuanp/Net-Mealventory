@page "/settings"

<h3>Notification Settings</h3>

<label>
    <input type="checkbox" @bind="emailEnabled" />
    Enable Email Notifications
</label>

<br />

<button class="btn btn-primary" @onclick="Save">Save</button>

<p>@message</p>

@code {
    bool emailEnabled = true;
    string message = "";

    void Save()
    {
        message = "Settings saved!";
    }
}
