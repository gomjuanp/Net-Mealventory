@page "/login"
@using Mealventory.Core.Models
@using Mealventory.Web.Services
@inject AuthApiService AuthApi
@inject AppState AppState
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<div class="row justify-content-center">
    <div class="col-md-6">
        <h3 class="mb-3">Login to Mealventory</h3>
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger">@errorMessage</div>
        }
        <div class="card p-4 shadow-sm" style="border-top: 5px solid #8db600;">
            <EditForm Model="@loginModel" OnValidSubmit="HandleLogin" FormName="loginForm">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-3">
                    <label>Email</label>
                    <InputText @bind-Value="loginModel.Email" class="form-control" />
                </div>
                <div class="mb-3">
                    <label>Password</label>
                    <InputText @bind-Value="loginModel.Password" type="password" class="form-control" />
                </div>
                <button type="submit" class="btn text-white w-100" style="background-color:#8db600;">Login</button>
            </EditForm>
            <div class="mt-3 text-center">
                <a href="/register" style="color: #8db600;">Don't have an account? Register here.</a>
            </div>
        </div>
    </div>
</div>

@code {
    /// Field to store user login input values.
    private LoginRequest loginModel = new();

    /// Field to store login error messages for display.
    private string? errorMessage;

    /// Method to submit login credentials and establish user session state.
    private async Task HandleLogin()
    {
        errorMessage = null;

        try
        {
            var response = await AuthApi.LoginAsync(loginModel);

            if (response.IsSuccessStatusCode)
            {
                var user = await response.Content.ReadFromJsonAsync<AuthUserResponse>();

                if (user != null)
                {
                    AppState.LogIn(user.Id, user.Username);
                    await JS.InvokeVoidAsync("mealventoryAuth.saveUser", user.Id, user.Username);
                    NavigationManager.NavigateTo("/");
                }
                else
                {
                    errorMessage = "Login succeeded, but user data could not be loaded.";
                }
            }
            else
            {
                errorMessage = await response.Content.ReadAsStringAsync();

                if (string.IsNullOrWhiteSpace(errorMessage))
                {
                    errorMessage = "Invalid login credentials.";
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Login failed: {ex.Message}";
        }
    }
}