@page "/"
@using Mealventory.Core.Models
@using Mealventory.Web.Services
@inject FoodApiService FoodApi
@inject AppState AppState
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<PageTitle>Mealventory - Dashboard</PageTitle>

@if (!AppState.CurrentUserId.HasValue)
{
    <div class="text-center mt-5">
        <h1 style="color: #000;">Welcome to <span style="color: #8db600;">Mealventory</span></h1>
        <p class="lead mt-3">Keep track of your food and avoid expiration!</p>
        <div class="mt-4">
            <a href="/login" class="btn text-white me-2" style="background-color: #8db600; width: 120px;">Login</a>
            <a href="/register" class="btn btn-dark" style="width: 120px;">Register</a>
        </div>
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Hello, @AppState.CurrentUserName!</h2>
        <button class="btn btn-outline-dark" @onclick="Logout">Logout</button>
    </div>

    <div class="row mb-4">
        <div class="col">
            <div class="card p-4 shadow-sm" style="border-top: 5px solid #8db600;">
                <h4>Add New Item</h4>

                @if (!string.IsNullOrWhiteSpace(addErrorMessage))
                {
                    <div class="alert alert-danger mt-3">@addErrorMessage</div>
                }

                <EditForm Model="newItem" OnValidSubmit="AddItem" FormName="addFoodItemForm">
                    <div class="row g-3 align-items-end">

                        <div class="col-md-3">
                            <label>Food Name</label>
                            <InputText @bind-Value="newItem.Name" class="form-control" placeholder="e.g. Milk" />
                        </div>

                        <div class="col-md-2">
                            <label>Expiration Date</label>
                            <InputDate @bind-Value="newItem.ExpirationDate" class="form-control" />
                        </div>

                        <div class="col-md-2">
                            <label>Quantity</label>
                            <InputNumber @bind-Value="newItem.Quantity" class="form-control" />
                        </div>

                        <div class="col-md-2">
                            <label>Location</label>
                            <InputSelect @bind-Value="newItem.Location" class="form-control">
                                <option value="Fridge">Fridge</option>
                                <option value="Pantry">Pantry</option>
                            </InputSelect>
                        </div>

                        <div class="col-md-3">
                            <button type="submit" class="btn text-white w-100" style="background-color: #8db600;">
                                Add to Inventory
                            </button>
                        </div>

                    </div>
                </EditForm>
            </div>
        </div>
    </div>

    @if (Notifications.Any())
    {
        <div class="alert alert-warning shadow-sm">
            <h5 class="alert-heading">Expiring Soon!</h5>
            <ul class="mb-0">
                @foreach (var note in Notifications)
                {
                    <li>@note</li>
                }
            </ul>
        </div>
    }

    <h4>Your Inventory</h4>
    @if (foodItems == null)
    {
        <p><em>Loading your inventory...</em></p>
    }
    else if (!foodItems.Any())
    {
        <p>Your inventory is empty. Add some items above!</p>
    }
    else
    {
        <table class="table table-hover shadow-sm bg-white">
            <thead class="table-dark">
                <tr>
                    <th>Name</th>
                    <th>Quantity</th>
                    <th>Expiration Date</th>
                    <th>Location</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in foodItems.OrderBy(f => f.ExpirationDate))
                {
                    var isExpired = item.ExpirationDate.Date < DateTime.Today;
                    var isExpiringSoon = !isExpired && item.ExpirationDate.Date <= DateTime.Today.AddDays(3);

                    <tr class="@(isExpired ? "table-danger" : (isExpiringSoon ? "table-warning" : ""))">
                        <td>@item.Name</td>
                        <td>@item.Quantity</td>
                        <td>@item.ExpirationDate.ToShortDateString()</td>
                        <td>
                            <span class="badge bg-secondary">@item.Location</span>
                        </td>
                        <td>
                            @if (isExpired)
                            {
                                <span class="badge bg-danger">Expired</span>
                            }
                            else if (isExpiringSoon)
                            {
                                <span class="badge bg-warning text-dark">Expiring Soon</span>
                            }
                            else
                            {
                                <span class="badge" style="background-color: #8db600;">Fresh</span>
                            }
                        </td>
                        <td>
                            <button class="btn btn-sm btn-danger" @onclick="() => DeleteItem(item.Id)">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

@code {
    private List<FoodItem>? foodItems;

    private FoodItem newItem = new()
    {
        ExpirationDate = DateTime.Today.AddDays(7),
        Quantity = 1,
        Location = "Pantry"
    };

    private List<string> Notifications = new();
    private string? addErrorMessage;

    private class StoredUser
    {
        public string? userId { get; set; }
        public string? username { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        AppState.OnChange += StateHasChanged;

        if (!AppState.CurrentUserId.HasValue)
        {
            try
            {
                var storedUser = await JS.InvokeAsync<StoredUser>("mealventoryAuth.getUser");

                if (storedUser != null &&
                    int.TryParse(storedUser.userId, out var userId) &&
                    !string.IsNullOrWhiteSpace(storedUser.username))
                {
                    AppState.RestoreUser(userId, storedUser.username);
                }
            }
            catch { }
        }

        if (AppState.CurrentUserId.HasValue)
        {
            await LoadItems();
        }
    }

    private async Task LoadItems()
    {
        if (!AppState.CurrentUserId.HasValue)
            return;

        try
        {
            foodItems = await FoodApi.GetItemsAsync(AppState.CurrentUserId.Value) ?? new List<FoodItem>();
            GenerateNotifications();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading items: {ex.Message}");
        }
    }

    private void GenerateNotifications()
    {
        Notifications.Clear();

        if (foodItems == null)
            return;

        foreach (var item in foodItems)
        {
            if (item.ExpirationDate.Date == DateTime.Today)
                Notifications.Add($"Your {item.Name} expires today!");
            else if (item.ExpirationDate.Date < DateTime.Today)
                Notifications.Add($"Your {item.Name} has expired.");
            else if (item.ExpirationDate.Date <= DateTime.Today.AddDays(3))
                Notifications.Add($"Your {item.Name} will expire on {item.ExpirationDate.ToShortDateString()}.");
        }
    }

    private async Task AddItem()
    {
        addErrorMessage = null;

        if (!AppState.CurrentUserId.HasValue)
            return;

        if (string.IsNullOrWhiteSpace(newItem.Name))
        {
            addErrorMessage = "Food name cannot be empty.";
            return;
        }

        newItem.Name = newItem.Name.Trim();
        newItem.UserId = AppState.CurrentUserId.Value;

        try
        {
            var response = await FoodApi.AddItemAsync(newItem);

            if (response.IsSuccessStatusCode)
            {
                newItem = new FoodItem
                {
                    ExpirationDate = DateTime.Today.AddDays(7),
                    Quantity = 1,
                    Location = "Pantry"
                };

                await LoadItems();
            }
            else
            {
                addErrorMessage = await response.Content.ReadAsStringAsync();
                if (string.IsNullOrWhiteSpace(addErrorMessage))
                    addErrorMessage = "Could not add item.";
            }
        }
        catch (Exception ex)
        {
            addErrorMessage = $"Error adding item: {ex.Message}";
        }
    }

    private async Task DeleteItem(int id)
    {
        if (!AppState.CurrentUserId.HasValue)
            return;

        try
        {
            var response = await FoodApi.DeleteItemAsync(id, AppState.CurrentUserId.Value);
            if (response.IsSuccessStatusCode)
                await LoadItems();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error deleting item: {ex.Message}");
        }
    }

    private async Task Logout()
    {
        AppState.LogOut();
        await JS.InvokeVoidAsync("mealventoryAuth.clearUser");
        NavigationManager.NavigateTo("/", forceLoad: true);
    }

    public void Dispose()
    {
        AppState.OnChange -= StateHasChanged;
    }
}