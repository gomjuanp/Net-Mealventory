@page "/register"
@using Mealventory.Core.Models
@using Mealventory.Web.Services
@inject IHttpClientFactory HttpClientFactory
@inject AppState AppState
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<div class="row justify-content-center">
    <div class="col-md-6">
        <h3 class="mb-3">Register for Mealventory</h3>
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger">@errorMessage</div>
        }
        <div class="card p-4 shadow-sm" style="border-top: 5px solid #8db600;">
            <EditForm Model="@registerModel" OnValidSubmit="HandleRegister" FormName="registerForm">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-3">
                    <label>Username</label>
                    <InputText @bind-Value="registerModel.Username" class="form-control" />
                </div>
                <div class="mb-3">
                    <label>Email</label>
                    <InputText @bind-Value="registerModel.Email" class="form-control" />
                </div>
                <div class="mb-3">
                    <label>Password</label>
                    <InputText @bind-Value="registerModel.PasswordHash" type="password" class="form-control" />
                </div>
                <button type="submit" class="btn text-white w-100" style="background-color:#8db600;">Register</button>
            </EditForm>
            <div class="mt-3 text-center">
                <a href="/login" style="color: #8db600;">Already have an account? Login here.</a>
            </div>
        </div>
    </div>
</div>

@code {
    private User registerModel = new();
    private string? errorMessage;

    private async Task HandleRegister()
    {
        errorMessage = null;
        var client = HttpClientFactory.CreateClient("API");

        try
        {
            var response = await client.PostAsJsonAsync("api/auth/register", registerModel);

            if (response.IsSuccessStatusCode)
            {
                var user = await response.Content.ReadFromJsonAsync<AuthUserResponse>();

                if (user != null)
                {
                    AppState.LogIn(user.Id, user.Username);
                    await JS.InvokeVoidAsync("mealventoryAuth.saveUser", user.Id, user.Username);
                    NavigationManager.NavigateTo("/");
                }
                else
                {
                    errorMessage = "Registration succeeded, but user data could not be loaded.";
                }
            }
            else
            {
                errorMessage = await response.Content.ReadAsStringAsync();

                if (string.IsNullOrWhiteSpace(errorMessage))
                {
                    errorMessage = "Registration failed.";
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Registration failed: {ex.Message}";
        }
    }
}